# =============================================================================
# DigitalBase Configuration — Ollama Edition
# =============================================================================
# このファイルを ~/.local/db/.env にコピーして編集してください。
#   cp templates/example.env ~/.local/db/.env
#   chmod 600 ~/.local/db/.env
# =============================================================================

# ── Database (必須) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://digitalbase:digitalbase@host.docker.internal:5432/digitalbase

# ── LLM Backend (必須) ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CONTEXT_LENGTH=16384

FILES_DIR=/app/data/files

# ── Authentication (必須) ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-random-32byte-hex
OAUTH_ENCRYPTION_KEY=
AUTH_MODE=local

# ── Cloud LLM Provider (任意) ────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ── LDAP / Active Directory (任意) ───────────────────────────────────────────
# LDAP_SERVER=ldap://ad.example.local
# LDAP_BIND_DN=CN=svc,DC=example,DC=local
# LDAP_BIND_PASSWORD=
# LDAP_BASE_DN=DC=example,DC=local
# LDAP_USE_TLS=true

# ── License (任意) ───────────────────────────────────────────────────────────
# LICENSE_FILE_PATH=/app/data/license.lic

# ── Server (任意) ────────────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
