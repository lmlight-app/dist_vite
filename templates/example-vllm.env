# =============================================================================
# DigitalBase Configuration — vLLM Edition (GPU 必須)
# =============================================================================
# このファイルを ~/.local/db-vllm/.env にコピーして編集してください。
#   cp templates/example-vllm.env ~/.local/db-vllm/.env
#   chmod 600 ~/.local/db-vllm/.env
# =============================================================================

# ── Database (必須) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://digitalbase:digitalbase@host.docker.internal:5432/digitalbase

# ── File storage (必須、bind mount に書く) ──────────────────────────────────
# /app/data は host の $DATA_DIR に bind mount、container 削除で消えない
FILES_DIR=/app/data/files

# ── vLLM Backend (必須) ──────────────────────────────────────────────────────
# コンテナ内 vLLM を使う場合は localhost、外部 vLLM サーバなら URL を変える
VLLM_BASE_URL=http://localhost:8080
VLLM_EMBED_BASE_URL=http://localhost:8081
# コンテナ内で vLLM を自動起動する
VLLM_AUTO_START=true

# ── Models (任意、デフォルトは小型モデル) ────────────────────────────────────
# VLLM_CHAT_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# VLLM_EMBED_MODEL=intfloat/multilingual-e5-large-instruct
# VLLM_VISION_MODEL=                   # 空=Vision は chat server を流用
# WHISPER_MODEL=base                   # tiny / base / small / medium / large-v3

# ── GPU 設定 (任意、GPU メモリに応じて調整) ──────────────────────────────────
# VLLM_TENSOR_PARALLEL=1               # マルチ GPU なら 2, 4, 8
# VLLM_GPU_MEMORY_UTILIZATION_CHAT=0.55
# VLLM_GPU_MEMORY_UTILIZATION_EMBED=0.35
# VLLM_GPU_MEMORY_UTILIZATION_VISION=
# VLLM_MAX_MODEL_LEN=                  # 空=モデルの max を使う

# ── Reasoning (Thinking) ─────────────────────────────────────────────────────
# モデルが thinking 対応している場合に設定 (parser 名)
#   qwen3       — Qwen 3 / 3.5
#   gemma4      — Gemma 4
#   deepseek_r1 — DeepSeek R1
# VLLM_REASONING_PARSER=qwen3

# ── Tool Calling (Function Calling) ──────────────────────────────────────────
# vLLM は対応モデルなら HuggingFace の tokenizer_config.json から自動検知。
# 自動検知されない / 別 parser を使いたい場合のみ設定。
#
# Gemma 4 (バンドル template 必要):
# VLLM_EXTRA_ARGS_CHAT="--enable-auto-tool-choice --tool-call-parser gemma4 --chat-template tool_chat_template_gemma4.jinja"
#
# Qwen 2.5 系:
# VLLM_EXTRA_ARGS_CHAT="--enable-auto-tool-choice --tool-call-parser hermes"
#
# Qwen 3:
# VLLM_EXTRA_ARGS_CHAT="--enable-auto-tool-choice --tool-call-parser qwen3_xml"
#
# Llama 3.0/3.1:
# VLLM_EXTRA_ARGS_CHAT="--enable-auto-tool-choice --tool-call-parser llama3_json"
#
# Llama 3.2/3.3:
# VLLM_EXTRA_ARGS_CHAT="--enable-auto-tool-choice --tool-call-parser pythonic"
#
# Mistral / Mixtral:
# VLLM_EXTRA_ARGS_CHAT="--enable-auto-tool-choice --tool-call-parser mistral"

# ── Authentication (必須) ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-random-32byte-hex
OAUTH_ENCRYPTION_KEY=
AUTH_MODE=local

# ── Cloud LLM Provider (任意) ────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ── LDAP / Active Directory (任意) ───────────────────────────────────────────
# LDAP_SERVER=ldap://ad.example.local
# LDAP_BIND_DN=CN=svc,DC=example,DC=local
# LDAP_BIND_PASSWORD=
# LDAP_BASE_DN=DC=example,DC=local
# LDAP_USE_TLS=true

# ── License (オプション) ─────────────────────────────────────────────────────
# LICENSE_FILE_PATH=/app/data/license.lic

# ── Server (オプション) ──────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
