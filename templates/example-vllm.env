# =============================================================================
# DigitalBase Configuration — vLLM Edition (GPU 必須)
# =============================================================================
# このファイルを ~/.local/db-vllm/.env にコピーして編集してください。
#   cp templates/example-vllm.env ~/.local/db-vllm/.env
#   chmod 600 ~/.local/db-vllm/.env
# =============================================================================

# ── Database (必須) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://digitalbase:digitalbase@host.docker.internal:5432/digitalbase

# ── File storage (必須) ──────────────────────────────────────────────────────
FILES_DIR=/app/data/files

# ── vLLM Backend (必須) ──────────────────────────────────────────────────────
VLLM_BASE_URL=http://localhost:8080
VLLM_EMBED_BASE_URL=http://localhost:8081
VLLM_AUTO_START=true

# ── Models (任意) ────────────────────────────────────────────────────────────
# VLLM_CHAT_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# VLLM_EMBED_MODEL=intfloat/multilingual-e5-large-instruct
# VLLM_VISION_MODEL=
# WHISPER_MODEL=base

# ── GPU 設定 (任意) ──────────────────────────────────────────────────────────
# VLLM_TENSOR_PARALLEL=1
# VLLM_GPU_MEMORY_UTILIZATION_CHAT=0.55
# VLLM_GPU_MEMORY_UTILIZATION_EMBED=0.35
# VLLM_GPU_MEMORY_UTILIZATION_VISION=
# VLLM_MAX_MODEL_LEN=

# ── Reasoning (任意) ─────────────────────────────────────────────────────────
# VLLM_REASONING_PARSER=qwen3

# ── Tool Calling (任意) ──────────────────────────────────────────────────────
# VLLM_EXTRA_ARGS_CHAT="--enable-auto-tool-choice --tool-call-parser hermes"

# ── Authentication (必須) ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-random-32byte-hex
OAUTH_ENCRYPTION_KEY=
AUTH_MODE=local

# ── Cloud LLM Provider (任意) ────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ── LDAP / Active Directory (任意) ───────────────────────────────────────────
# LDAP_SERVER=ldap://ad.example.local
# LDAP_BIND_DN=CN=svc,DC=example,DC=local
# LDAP_BIND_PASSWORD=
# LDAP_BASE_DN=DC=example,DC=local
# LDAP_USE_TLS=true

# ── License (オプション) ─────────────────────────────────────────────────────
# LICENSE_FILE_PATH=/app/data/license.lic

# ── Server (オプション) ──────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
