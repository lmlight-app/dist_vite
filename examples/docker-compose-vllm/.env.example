# DigitalBase vLLM Edition - environment variables
# Copy to .env and edit values for your environment.

# ── Required: change these for production ──────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-to-random-32-byte-hex   # openssl rand -hex 32

# ── Optional: image tag (use a specific version in production) ─────────
IMAGE_TAG=1                          # 1.2.3 (immutable) | 1.2 | 1 | latest

# ── Optional: API port on host ─────────────────────────────────────────
API_PORT=8000

# ── Optional: Postgres credentials (defaults work for most setups) ─────
POSTGRES_USER=digitalbase
POSTGRES_DB=digitalbase

# ── Optional: model selection ─────────────────────────────────────────
VLLM_CHAT_MODEL=google/gemma-4-E2B-it
VLLM_EMBED_MODEL=google/embeddinggemma-300m
VLLM_MAX_MODEL_LEN=4096

# ── Optional: GPU memory split ────────────────────────────────────────
# Sum should be < 1.0 (leaves room for CUDA overhead).
# Single GPU: chat 0.55 + embed 0.35 = 0.90
# Separate GPUs: bump both to 0.85
VLLM_GPU_MEM_CHAT=0.55
VLLM_GPU_MEM_EMBED=0.35

# ── Optional: Whisper model ───────────────────────────────────────────
# tiny (74MB) | base (140MB) | small (460MB) | medium (1.5GB) | large (3GB)
ASR_MODEL=base

# ── Optional: HuggingFace cache location ──────────────────────────────
# Share with host so models persist across `docker compose down`.
HF_HOME=/home/yourname/.cache/huggingface

# ── Authentication ────────────────────────────────────────────────────
AUTH_MODE=local                      # local | ldap | oidc

# ── Optional: LDAP / OIDC settings (only if AUTH_MODE is set) ─────────
# LDAP_HOST=
# LDAP_BASE_DN=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_TENANT_ID=
